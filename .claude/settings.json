{
  "env": {
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cargo build:*)", "Bash(cargo test:*)", "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)", "Bash(cargo doc:*)", "Bash(cargo run:*)",
      "Bash(uv run:*)", "Bash(uv sync:*)", "Bash(uv add:*)",
      "Bash(git status)", "Bash(git diff:*)", "Bash(git log:*)", "Bash(git add:*)",
      "Bash(rustup:*)", "Bash(gh pr:*)", "Bash(gh issue:*)", "Bash(gh run:*)",
      "Read(//D:/*/git/gpu/**)",
      "Edit(//D:/*/git/gpu/**)",
      "Read(//c/GIT Repos/**)",
      "Read(//c/Users/neomo/AppData/Local/MDT/MDT_Testing/**)",
      "Read",
      "Write",
      "WebSearch",
      "WebFetch(domain:*)",
      "Bash(*)",
      "PowerShell(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(chown *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(rm *)",
      "PowerShell(del *)"
    ],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -c \"import os,sys,runpy;runpy.run_path(os.path.expanduser('~/.claude/hooks/'+sys.argv[1]),run_name='__main__')\" github_issue_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py -c \"import os,sys,runpy;runpy.run_path(os.path.expanduser('~/.claude/hooks/'+sys.argv[1]),run_name='__main__')\" protect_claude_md.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py -c \"import os,sys,runpy;runpy.run_path(os.path.expanduser('~/.claude/hooks/'+sys.argv[1]),run_name='__main__')\" emoji_remover.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.exe",
    "refreshInterval": 1
  },
  "enabledPlugins": {
    "data@knowledge-work-plugins": false,
    "superpowers@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}